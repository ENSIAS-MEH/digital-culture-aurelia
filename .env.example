# Copy this file to .env and fill in real values — NEVER commit .env

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=change_me_strong_password

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be >= 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=change_me_at_least_32_chars_long_secret_here

# ── AI / LLM ──────────────────────────────────────────────────────────────────
OLLAMA_MODEL=llama3.2

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Local:      http://localhost:5173
# Production: https://yourapp.example.com
CORS_ORIGIN=http://localhost:5173

# ── Frontend (baked in at Vite build time) ────────────────────────────────────
# Set to your server's public address when deploying
VITE_BACKEND_URL=http://localhost:8080
VITE_AI_SERVICE_URL=http://localhost:8000
