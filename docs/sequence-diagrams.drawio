<mxfile host="app.diagrams.net" type="device">
  <!-- ==================== PAGE 1: Document Upload Flow ==================== -->
  <diagram name="1 - Document Upload" id="seq-upload">
    <mxGraphModel dx="1422" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="t1" value="Document Upload Flow" style="text;fontSize=18;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="500" y="10" width="300" height="30" as="geometry"/>
        </mxCell>

        <!-- Lifelines -->
        <mxCell id="2" value="User" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#dae8fc;strokeColor=#6c8ebf;size=40;" vertex="1" parent="1">
          <mxGeometry x="80" y="60" width="100" height="780" as="geometry"/>
        </mxCell>
        <mxCell id="3" value="React&#xa;Frontend" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#dae8fc;strokeColor=#6c8ebf;size=40;" vertex="1" parent="1">
          <mxGeometry x="280" y="60" width="100" height="780" as="geometry"/>
        </mxCell>
        <mxCell id="4" value="Jakarta EE&#xa;Backend" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#d5e8d4;strokeColor=#82b366;size=40;" vertex="1" parent="1">
          <mxGeometry x="500" y="60" width="100" height="780" as="geometry"/>
        </mxCell>
        <mxCell id="5" value="PostgreSQL" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#e1d5e7;strokeColor=#9673a6;size=40;" vertex="1" parent="1">
          <mxGeometry x="720" y="60" width="100" height="780" as="geometry"/>
        </mxCell>
        <mxCell id="6" value="FastAPI&#xa;AI Service" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#fff2cc;strokeColor=#d6b656;size=40;" vertex="1" parent="1">
          <mxGeometry x="940" y="60" width="100" height="780" as="geometry"/>
        </mxCell>
        <mxCell id="7" value="ChromaDB" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#ffe6cc;strokeColor=#d79b00;size=40;" vertex="1" parent="1">
          <mxGeometry x="1150" y="60" width="100" height="780" as="geometry"/>
        </mxCell>

        <!-- Messages -->
        <mxCell id="10" value="1. Select file &amp; Upload" style="endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="130" y="130" as="sourcePoint"/>
            <mxPoint x="330" y="130" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="11" value="2. POST /api/documents" style="endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="180" as="sourcePoint"/>
            <mxPoint x="550" y="180" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="12" value="3. Save Document (status=UPLOADED)" style="endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="550" y="230" as="sourcePoint"/>
            <mxPoint x="770" y="230" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="13" value="4. 202 Accepted" style="endArrow=open;endFill=0;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="550" y="280" as="sourcePoint"/>
            <mxPoint x="330" y="280" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="14" value="5. &quot;Processing...&quot;" style="endArrow=open;endFill=0;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="320" as="sourcePoint"/>
            <mxPoint x="130" y="320" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="15" value="6. POST /ai/parse (file)" style="endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="550" y="380" as="sourcePoint"/>
            <mxPoint x="990" y="380" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="16" value="7. Extract text &amp; parse transactions" style="endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1000" y="430" as="sourcePoint"/>
            <mxPoint x="1000" y="470" as="targetPoint"/>
            <Array as="points">
              <mxPoint x="1060" y="430"/>
              <mxPoint x="1060" y="470"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="17" value="8. Store embeddings" style="endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="990" y="520" as="sourcePoint"/>
            <mxPoint x="1200" y="520" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="18" value="9. Parsed transactions" style="endArrow=open;endFill=0;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="990" y="580" as="sourcePoint"/>
            <mxPoint x="550" y="580" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="19" value="10. Save Transactions" style="endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="550" y="630" as="sourcePoint"/>
            <mxPoint x="770" y="630" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="20" value="11. Update status=PROCESSED" style="endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="550" y="680" as="sourcePoint"/>
            <mxPoint x="770" y="680" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="21" value="12. Processing complete" style="endArrow=open;endFill=0;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="550" y="730" as="sourcePoint"/>
            <mxPoint x="330" y="730" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="22" value="13. &quot;X transactions found&quot;" style="endArrow=open;endFill=0;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="770" as="sourcePoint"/>
            <mxPoint x="130" y="770" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

