# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=change_me_strong_password
DB_HOST=postgres
DB_PORT=5432
DB_NAME=aurelia
DB_USER=aurelia

# Full JDBC URL used by WildFly (built from above vars in entrypoint.sh)
# DATABASE_URL=jdbc:postgresql://postgres:5432/aurelia

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_256bit_random_secret_here

# ── AI / Anthropic ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ── Service URLs (for local dev without Docker) ───────────────────────────────
AI_SERVICE_URL=http://localhost:8000
BACKEND_URL=http://localhost:8080
CHROMA_HOST=localhost
CHROMA_PORT=8002

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_BACKEND_URL=http://localhost:8080
VITE_AI_SERVICE_URL=http://localhost:8000
