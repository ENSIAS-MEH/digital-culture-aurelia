# Copy this file to .env and fill in real values — NEVER commit .env

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=change_me_strong_password

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be >= 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=change_me_at_least_32_chars_long_secret_here

# ── AI / LLM ──────────────────────────────────────────────────────────────────
OLLAMA_MODEL=llama3.2

# ── CORS ──────────────────────────────────────────────────────────────────────
# Local dev:   http://localhost:5173
# Production:  https://yourdomain.com
CORS_ORIGIN=http://localhost:5173

# ── Local dev only (baked into Vite bundle at build time) ────────────────────
# Leave these set for local dev. In production (docker-compose.prod.yml) these
# are intentionally empty so all requests use relative URLs through Caddy.
# NOTE: Backend is mapped to host port 8090 (avoids conflict with system Tomcat on 8080).
# Mobile (Android emulator) uses http://10.0.2.2:8090 — same backend, same database.
VITE_BACKEND_URL=http://localhost:8090
VITE_AI_SERVICE_URL=http://localhost:8000

# ── Production only ───────────────────────────────────────────────────────────
# Your public domain (with or without https://).
# Caddy uses this to obtain a Let's Encrypt TLS certificate automatically.
# Examples:
#   DOMAIN=aurelia.example.com
#   DOMAIN=192.0.2.1          (IP address — HTTP only, no auto-TLS)
DOMAIN=aurelia.example.com
